CODE 1: perform exploratory data analysis (EDA)

import pandas as pd

# Load dataset
df = pd.read_csv("sentimentdataset.csv")

# Preview dataset
print("First 5 rows:")
print(df.head())

# Dataset information
print("\nDataset Info:")
print(df.info())

# Statistical summary
print("\nDescriptive Statistics:")
print(df.describe())

# Missing values
print("\nMissing Values:")
print(df.isnull().sum())

# Average likes
if "Likes" in df.columns:
    print("\nAverage Likes:", df["Likes"].mean())

# Platform frequency
if "Platform" in df.columns:
    print("\nPlatform Frequency:")
    print(df["Platform"].value_counts())

# Correlation between Likes and Retweets
if {"Likes", "Retweets"}.issubset(df.columns):
    print("\nCorrelation:")
    print(df[["Likes", "Retweets"]].corr())

# Skewness of Likes
if "Likes" in df.columns:
    print("\nSkewness of Likes:", df["Likes"].skew())

# Average likes by platform
if {"Platform", "Likes"}.issubset(df.columns):
    print("\nAverage Likes per Platform:")
    print(df.groupby("Platform")["Likes"].mean())

