import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Load dataset
df = pd.read_csv("sentimentdataset.csv")

# Convert timestamp
df["Timestamp"] = pd.to_datetime(df["Timestamp"])
df["Date"] = df["Timestamp"].dt.date

# 1. Line Plot - Likes over time
daily_likes = df.groupby("Date")["Likes"].sum()
plt.plot(daily_likes.index, daily_likes.values, marker="o")
plt.title("Likes Trend Over Time")
plt.xticks(rotation=45)
plt.show()

# 2. Scatter Plot - Likes vs Retweets
sns.scatterplot(x="Likes", y="Retweets", data=df)
plt.title("Likes vs Retweets")
plt.show()

# 3. Bar Plot - Average Likes per Platform
sns.barplot(x="Platform", y="Likes", data=df)
plt.title("Average Likes per Platform")
plt.xticks(rotation=45)
plt.show()

# 4. Histogram - Likes Distribution
sns.histplot(df["Likes"], kde=True)
plt.title("Distribution of Likes")
plt.show()

# 5. Box Plot - Likes by Platform
sns.boxplot(x="Platform", y="Likes", data=df)
plt.title("Likes Distribution per Platform")
plt.xticks(rotation=45)
plt.show()

# 6. Heatmap - Correlation
corr = df[["Likes", "Retweets"]].corr()
sns.heatmap(corr, annot=True)
plt.title("Correlation Heatmap")
plt.show()

# 7. Pie Chart - Sentiment Distribution
sentiment_count = df["Sentiment"].value_counts()
plt.pie(sentiment_count, labels=sentiment_count.index, autopct="%1.1f%%")
plt.title("Sentiment Proportion")
plt.show()

# 8. Count Plot - Posts per Platform
sns.countplot(x="Platform", data=df)
plt.title("Posts per Platform")
plt.xticks(rotation=45)
plt.show()

