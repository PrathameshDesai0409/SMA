import pandas as pd
from google_play_scraper import reviews, Sort

apps = {
    "Uber": "com.ubercab",
    "Ola": "com.olacabs.customer",
    "Rapido": "com.rapido.passenger"
}

data = []

for brand, app_id in apps.items():
    print(f"Scraping {brand}...")

    try:
        result, _ = reviews(
            app_id,
            lang="en",
            country="us",
            sort=Sort.NEWEST,
            count=20
        )

        for r in result:
            data.append({
                "Brand": brand,
                "Rating": r["score"],
                "Review": r["content"],
                "Date": r["at"]
            })

        print(f"{len(result)} reviews scraped for {brand}")

    except Exception as e:
        print(f"Error scraping {brand}: {e}")

df = pd.DataFrame(data)
df.to_csv("competitor_reviews.csv", index=False)

print("Data saved successfully!")

