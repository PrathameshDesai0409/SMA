import pandas as pd
from textblob import TextBlob
import matplotlib.pyplot as plt

# Load data
df = pd.read_csv("competitor_reviews.csv")

# Sentiment analysis
def get_sentiment(text):
    score = TextBlob(str(text)).sentiment.polarity

    if score > 0.05:
        return "Positive"
    elif score < -0.05:
        return "Negative"
    else:
        return "Neutral"

df["Sentiment"] = df["Review"].apply(get_sentiment)

# Group data
summary = df.groupby(["Sentiment", "Brand"]).size().unstack(fill_value=0)
summary_percentage = (summary / summary.sum()) * 100

# Plot graph
summary_percentage.plot(kind="bar", figsize=(10,6))

plt.title("Sentiment Analysis of Mobility Apps")
plt.ylabel("Percentage")
plt.xticks(rotation=0)
plt.show()

