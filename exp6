import pandas as pd
import networkx as nx
import matplotlib.pyplot as plt

# Load dataset
try:
    df = pd.read_csv("OBS_data.txt", sep="\t").head(100)
except FileNotFoundError:
    print("File not found")
    exit()

# Create directed graph
G_full = nx.from_pandas_edgelist(
    df,
    source="Actor",
    target="Recipient",
    create_using=nx.DiGraph()
)

# Largest connected component
largest = max(nx.weakly_connected_components(G_full), key=len)
G = G_full.subgraph(largest).copy()

# Visualize graph
plt.figure(figsize=(10,6))
pos = nx.spring_layout(G, seed=42)

nx.draw(G, pos,
        with_labels=True,
        node_color="lightgreen",
        node_size=800,
        arrows=True)

plt.title("Primate Social Network")
plt.show()

# Basic metrics
print("Nodes:", G.number_of_nodes())
print("Edges:", G.number_of_edges())
print("Density:", nx.density(G))

# Centrality measures
degree = nx.degree_centrality(G)
betweenness = nx.betweenness_centrality(G)
closeness = nx.closeness_centrality(G)
eigenvector = nx.eigenvector_centrality(G, max_iter=1000)

# Top hubs
hubs = sorted(degree.items(), key=lambda x: x[1], reverse=True)[:3]

print("\nTop Hubs:")
for node, score in hubs:
    print(node, ":", score)

# Bridges
bridges = list(nx.bridges(G.to_undirected()))
print("\nBridges:", bridges[:3])

# Summary table
result = pd.DataFrame({
    "Degree": degree,
    "Betweenness": betweenness,
    "Closeness": closeness,
    "Eigenvector": eigenvector
}).sort_values(by="Eigenvector", ascending=False)

print("\nTop 5 Nodes:")
print(result.head())

